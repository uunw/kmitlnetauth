<Page x:Class="KmitlNetAuth.Tray.Pages.Setup.CredentialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Credentials"
    Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="520" HorizontalAlignment="Center">

            <!-- Heading -->
            <TextBlock Text="Your Credentials"
                       FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Enter your KMITL student credentials."
                       FontSize="13"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Credentials card -->
            <ui:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Username -->
                    <TextBlock Text="Student ID"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBox x:Name="UsernameBox"
                                PlaceholderText="e.g. 67012345"
                                Margin="0,0,0,4" />
                    <TextBlock x:Name="UsernameError"
                               Text="Student ID is required"
                               FontSize="11"
                               Foreground="#E81123"
                               Visibility="Collapsed"
                               Margin="0,0,0,8" />

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="0,12,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:PasswordBox x:Name="PasswordBox"
                                    PlaceholderText="Password"
                                    Margin="0,0,0,4" />
                    <TextBlock x:Name="PasswordError"
                               Text="Password is required"
                               FontSize="11"
                               Foreground="#E81123"
                               Visibility="Collapsed"
                               Margin="0,0,0,8" />

                    <!-- IP Address (optional) -->
                    <TextBlock Text="Static IP (optional)"
                               FontSize="12" FontWeight="SemiBold"
                               Margin="0,12,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBox x:Name="IpAddressBox"
                                PlaceholderText="Leave empty for auto-detect"
                                Margin="0,0,0,4" />
                    <TextBlock Text="Most users should leave this empty."
                               FontSize="11"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </ui:Card>

            <!-- Security note -->
            <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                <ui:SymbolIcon Symbol="ShieldCheckmark24"
                               FontSize="16"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Top" />
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Your password is stored securely using Windows DPAPI and never written in plain text." />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
