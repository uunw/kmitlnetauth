<Page x:Class="KmitlNetAuth.Tray.Pages.Setup.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Welcome"
    Background="Transparent">
    <Grid>
        <!-- Centered hero content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Margin="32">

            <!-- Logo -->
            <Border Width="112" Height="112" Margin="0,0,0,24"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="24">
                <Image Source="pack://application:,,,/Resources/app.ico"
                       Width="96" Height="96"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>

            <!-- Title -->
            <TextBlock Text="Welcome to KMITL NetAuth"
                       FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <!-- Subtitle -->
            <TextBlock Text="Let's get you connected to the KMITL network."
                       FontSize="15"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Description -->
            <TextBlock TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="13"
                       LineHeight="20"
                       Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="This app automatically authenticates you to the campus network so you don't have to log in manually each time. Once set up, it runs quietly in the background and keeps your connection alive." />

            <!-- Features card -->
            <ui:Card Padding="20,16" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <ui:SymbolIcon Symbol="Checkmark24"
                                       FontSize="18"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="Automatic login to campus Wi-Fi"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <ui:SymbolIcon Symbol="Checkmark24"
                                       FontSize="18"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="Stays connected with heartbeat"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <ui:SymbolIcon Symbol="Checkmark24"
                                       FontSize="18"
                                       Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="Runs silently in the system tray"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Call to action -->
            <TextBlock Text="Click Next to configure your credentials."
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
