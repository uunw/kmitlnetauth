<Page x:Class="KmitlNetAuth.Tray.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="About">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
        <StackPanel>
            <TextBlock Text="About" FontSize="28" FontWeight="Bold" Margin="0,0,0,24" />

            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="KMITL NetAuth" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock x:Name="VersionText" FontSize="14"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="Auto-authentication service for the KMITL network."
                        TextWrapping="Wrap" Margin="0,0,0,16" />

                    <TextBlock Text="License: MIT" FontSize="13" Margin="0,0,0,8"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <ui:HyperlinkButton Content="GitHub Repository" Margin="0,0,0,4"
                        NavigateUri="https://github.com/uunw/kmitlnetauth" />
                </StackPanel>
            </ui:Card>

            <!-- Update Section -->
            <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,12" />

            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="UpdateStatusText" Margin="0,0,0,12" />
                    <TextBlock x:Name="UpdateVersionText" Margin="0,0,0,12" Visibility="Collapsed"
                        FontWeight="SemiBold" />

                    <ProgressBar x:Name="DownloadProgress"
                        Minimum="0" Maximum="100" Value="0"
                        Visibility="Collapsed" Margin="0,0,0,8" />
                    <TextBlock x:Name="ProgressText" Visibility="Collapsed"
                        HorizontalAlignment="Center" FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="CheckUpdateButton" Content="Check for Updates"
                            Appearance="Primary" Click="OnCheckUpdateClicked" />
                        <ui:Button x:Name="InstallUpdateButton" Content="Install Update"
                            Margin="8,0,0,0" Visibility="Collapsed"
                            Click="OnInstallUpdateClicked" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
