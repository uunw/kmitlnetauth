<ui:FluentWindow x:Class="KmitlNetAuth.Tray.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="KMITL NetAuth Settings"
    Width="450" Height="500"
    MinWidth="450" MinHeight="500"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="KMITL NetAuth Settings" Grid.Row="0" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,24">
            <StackPanel>
                <ui:TextBox x:Name="UsernameBox"
                    PlaceholderText="Student ID"
                    Margin="0,0,0,16" />

                <ui:PasswordBox x:Name="PasswordBox"
                    PlaceholderText="Password"
                    Margin="0,0,0,16" />

                <ui:TextBox x:Name="IpAddressBox"
                    PlaceholderText="Auto-detect if empty"
                    Margin="0,0,0,16" />

                <TextBlock Text="Interval (seconds)" Margin="0,0,0,4"
                    FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:NumberBox x:Name="IntervalBox"
                    Minimum="10" Maximum="86400"
                    SpinButtonPlacementMode="Inline"
                    Margin="0,0,0,16" />

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Auto Login" VerticalAlignment="Center" Grid.Column="0" />
                    <ui:ToggleSwitch x:Name="AutoLoginToggle" Grid.Column="1" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel" Margin="0,0,8,0"
                        Click="OnCancelClicked" />
                    <ui:Button x:Name="SaveButton" Content="Save"
                        Appearance="Primary"
                        Click="OnSaveClicked" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
