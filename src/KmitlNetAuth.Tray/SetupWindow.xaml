<ui:FluentWindow x:Class="KmitlNetAuth.Tray.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Setup - KMITL NetAuth"
    Width="720" Height="560"
    MinWidth="720" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Setup - KMITL NetAuth"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Page content -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Background="Transparent" />

        <!-- Footer bar -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Step indicator -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StepLabel"
                               Text="Step 1 of 3"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button x:Name="BackButton"
                               Content="Back"
                               MinWidth="88"
                               Margin="0,0,8,0"
                               Click="OnBackClicked" />
                    <ui:Button x:Name="NextButton"
                               Content="Next"
                               Appearance="Primary"
                               MinWidth="88"
                               Margin="0,0,8,0"
                               Click="OnNextClicked" />
                    <ui:Button x:Name="CancelButton"
                               Content="Cancel"
                               MinWidth="88"
                               Click="OnCancelClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
